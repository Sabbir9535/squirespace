  margin-top: 20px;
}

.controls button {
  background: #f4b349;
  border: none;
  color: white;
  width: 50px;
  height: 50px;
  margin: 0 10px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 20px;
}
</style>

<script>
const cards = document.querySelectorAll(".team-card");
let current = 0;

function updateSlider() {
  cards.forEach((card, i) => {
    let offset = i - current;

    if (offset < -Math.floor(cards.length / 2)) offset += cards.length;
    if (offset > Math.floor(cards.length / 2)) offset -= cards.length;

    let scale = offset === 0 ? 1 : 0.75;
    let rotate = offset * -25;
    let translateX = offset * 350;
    let opacity = 1 - Math.abs(offset) * 0.35;

    card.style.transform = `translate(calc(-50% + ${translateX}px), -50%) scale(${scale}) rotateY(${rotate}deg)`;
    card.style.opacity = opacity < 0 ? 0 : opacity;
    card.style.zIndex = 10 - Math.abs(offset);
  });
}

function next() {
  current = (current + 1) % cards.length;
  updateSlider();
}

function prev() {
  current = (current - 1 + cards.length) % cards.length;
  updateSlider();
}

setInterval(next, 6000);
updateSlider();
</script>
