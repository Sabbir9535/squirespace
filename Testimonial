}

.team-card {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 320px;
  min-height: 420px;
  transform-style: preserve-3d;
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  background: #b8d6c3;
  padding: 40px 30px;
  border-radius: 25px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.team-card img, .img-placeholder {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  margin-bottom: 15px;
  object-fit: cover;
  background: #A6927C; /* Placeholder for missing images */
}

.quote {
  font-style: italic;
  font-size: 16px;
  line-height: 1.6;
  color: #333;
  margin-bottom: 15px;
}

.team-card h4 {
  margin: 5px 0;
  color: #f5b349;
  font-size: 20px;
}

.team-card span {
  color: #D65733;
  font-size: 12px;
  font-weight: bold;
}

